# ── Firebase (public — safe to commit) ──────────────────────────────
# Find these in Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── InsightNet backend (Cloud Run URL after deployment) ──────────────
NEXT_PUBLIC_API_URL=https://insightnet-backend-XXXX-uc.a.run.app

# ── Optional site-password gate ──────────────────────────────────────
# If set, users must enter this password before accessing the app.
# After passing the gate they are silently signed in anonymously via Firebase.
# Leave empty to disable the password gate entirely.
SITE_PASSWORD=

