# ── Google / Firebase ────────────────────────────────────────────────
# Service account JSON as a single-line string.
# In Cloud Run, mount via Secret Manager (see deploy steps below).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternative: path to a service account .json file (local dev only)
# FIREBASE_SERVICE_ACCOUNT_FILE=./service-account.json

# ── LLM / Embeddings ────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── GitHub scraper ───────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── Auth & rate limits ───────────────────────────────────────────────
# Comma-separated Firebase UIDs allowed to call /ingest
ADMIN_UIDS=uid1,uid2

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=https://insightnet-eta.vercel.app

# Set to anything other than "production" to also allow localhost in CORS
ENV=production


# ════════════════════════════════════════════════════════════════════
# Cloud Run deployment steps
# ════════════════════════════════════════════════════════════════════
#
# 1. Build & push image
#    gcloud builds submit --tag gcr.io/YOUR_PROJECT/insightnet-backend ./backend
#
# 2. Store secrets in Secret Manager
#    echo -n '{"type":"service_account",...}' | gcloud secrets create firebase-sa --data-file=-
#    echo -n 'sk-or-...'  | gcloud secrets create openrouter-key   --data-file=-
#    echo -n 'ghp_...'    | gcloud secrets create github-token      --data-file=-
#    echo -n 'whsec_...'  | gcloud secrets create github-webhook    --data-file=-
#
# 3. Deploy to Cloud Run
#    gcloud run deploy insightnet-backend \
#      --image gcr.io/YOUR_PROJECT/insightnet-backend \
#      --region us-central1 \
#      --platform managed \
#      --allow-unauthenticated \
#      --memory 512Mi \
#      --cpu 1 \
#      --concurrency 80 \
#      --min-instances 0 \
#      --set-secrets "FIREBASE_SERVICE_ACCOUNT_JSON=firebase-sa:latest,OPENROUTER_API_KEY=openrouter-key:latest,GITHUB_TOKEN=github-token:latest,GITHUB_WEBHOOK_SECRET=github-webhook:latest" \
#      --set-env-vars "ADMIN_UIDS=uid1uid2,FRONTEND_URL=https://insightnet-eta.vercel.app,ENV=production"
#
# 4. Create Firestore vector indexes (run once per collection, dimension=512 for pplx-embed-v1-0.6b)
#    gcloud firestore indexes composite create \
#      --collection-group=tool_profiles \
#      --query-scope=COLLECTION \
#      --field-config field-path=embedding,vector-config='{"dimension":512,"flat":{}}'
#
#    gcloud firestore indexes composite create \
#      --collection-group=readme_chunks \
#      --query-scope=COLLECTION \
#      --field-config field-path=embedding,vector-config='{"dimension":512,"flat":{}}'
#
#    gcloud firestore indexes composite create \
#      --collection-group=code_chunks \
#      --query-scope=COLLECTION \
#      --field-config field-path=embedding,vector-config='{"dimension":512,"flat":{}}'
#
# 5. Grant Cloud Run service account permissions
#    gcloud projects add-iam-policy-binding YOUR_PROJECT \
#      --member="serviceAccount:YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com" \
#      --role="roles/datastore.user"
#
#    gcloud projects add-iam-policy-binding YOUR_PROJECT \
#      --member="serviceAccount:YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com" \
#      --role="roles/secretmanager.secretAccessor"

