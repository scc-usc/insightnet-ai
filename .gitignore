# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Environment / secrets ─────────────────────────────────────────────
.env
.env.local
.env*.local

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
.venv/

# ── Backend local data (scraped content, embeddings, logs) ────────────
backend/data/
backend/usage.jsonl
backend/judge_cache.json

# ── Node / Frontend ───────────────────────────────────────────────────
node_modules/
frontend/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
frontend/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
frontend/next-env.d.ts
